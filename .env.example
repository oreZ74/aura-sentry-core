# ══════════════════════════════════════════════════════════════════════════════
# AuraSentry – Environment Variables (Template)
# Copy this file to .env and fill in your actual values.
# IMPORTANT: Never commit the .env file to version control!
# ══════════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────────────────
# APP_PASSWORD – BCrypt hash of the admin password
#
# The application expects a pre-computed BCrypt hash here ($2a$ or $2b$ prefix).
# The plaintext password is NEVER stored – only the hash.
#
# Generate a hash:
#
# Option 1 – htpasswd (Linux/macOS, Apache package):
#   htpasswd -bnBC 10 "" "YourPlaintextPassword" | tr -d ':\n'
#
# Option 2 – Python (3.x, requires: pip install bcrypt):
#   python3 -c "import bcrypt; print(bcrypt.hashpw(b'YourPassword', bcrypt.gensalt(rounds=10)).decode())"
#
# Option 3 – Node.js (requires: npm install bcryptjs):
#   node -e "const b=require('bcryptjs'); console.log(b.hashSync('YourPassword', 10));"
#
# Option 4 – Online tool (for testing only – never enter production passwords!):
#   https://bcrypt-generator.com  (Rounds: 10)
#
# The resulting hash looks like:
#   $2a$10$abcdefghijklmnopqrstuuABCDEFGHIJKLMNOPQRSTUVWXYZ012345
#
# ──────────────────────────────────────────────────────────────────────────────
APP_PASSWORD=$2a$10$REPLACE_WITH_YOUR_BCRYPT_HASH_HERE

# ──────────────────────────────────────────────────────────────────────────────
# CredentialEncryptionService
# ──────────────────────────────────────────────────────────────────────────────
# 32-byte (256-bit) Base64-encoded key for AES-256-GCM credential encryption.
# Generate one with: openssl rand -base64 32
APP_ENCRYPTION_KEY=REPLACE_WITH_BASE64_32BYTE_KEY

# ──────────────────────────────────────────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────────────────────────────────────────
# Local dev: App verbindet sich zu localhost:5433 (Docker-Port-Mapping).
# In Docker:  docker-compose überschreibt SPRING_DATASOURCE_URL mit
#             jdbc:postgresql://postgres:5432/aurasentry (Service-Namen).
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=aurasentry
POSTGRES_USER=aurasentry
POSTGRES_PASSWORD=CHANGE_ME

# ──────────────────────────────────────────────────────────────────────────────
# Azure Service Principal
# ──────────────────────────────────────────────────────────────────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# ──────────────────────────────────────────────────────────────────────────────
# GitHub Container Registry (used by docker-compose pull)
# ──────────────────────────────────────────────────────────────────────────────
GITHUB_REPOSITORY=your-org/aura-sentry-core
GITHUB_USERNAME=your-github-username
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────────────────────────────────────
# Gemini API – AI-powered Remediation Engine
# ──────────────────────────────────────────────────────────────────────────────
# Google Cloud Console: https://console.cloud.google.com/apis/credentials
#
# GEMINI_API_KEY: Your generated API key (with Gemini API enabled)
#   Rate Limit: 15 requests/minute (free tier) – sufficient for cost analyses
#   Pricing: $0.00 per request (free tier available)
#
# GEMINI_MODEL_ID: The LLM model to use for remediation recommendations
#   Default: gemini-3.1-flash-lite-preview (fast, cost-effective)
#   Alternatives:
#     - gemini-pro (more capable, slightly more expensive)
#     - gemini-1.5-pro (highest quality, ~2x cost)
#     - gemini-1.5-flash (optimized for speed)
#
#   Changing this value does NOT require code recompilation!
#   Perfect for A/B testing different models without downtime.
#
GEMINI_API_KEY=
GEMINI_MODEL_ID=gemini-3.1-flash-lite-preview
