# ══════════════════════════════════════════════════════════════════════════════
# AuraSentry – Environment Variables (Template)
# Copy this file to .env and fill in your actual values.
# IMPORTANT: Never commit the .env file to version control!
#            It is already listed in .gitignore.
# ══════════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────────────────
# APP_PASSWORD – BCrypt hash of the admin web‑UI password
#
# The application expects a pre‑computed BCrypt hash ($2a$ or $2b$ prefix).
# The plaintext password is NEVER stored – only the hash.
#
# Generate a hash with one of:
#   htpasswd -bnBC 10 "" "YourPassword" | tr -d ':\n'
#   python3 -c "import bcrypt; print(bcrypt.hashpw(b'YourPassword', bcrypt.gensalt(rounds=10)).decode())"
#
# ──────────────────────────────────────────────────────────────────────────────
APP_PASSWORD=$2a$10$REPLACE_WITH_YOUR_BCRYPT_HASH_HERE

# ──────────────────────────────────────────────────────────────────────────────
# APP_ENCRYPTION_KEY – AES‑256‑GCM key for credential encryption (32 bytes, Base64)
#
# Generate with: openssl rand -base64 32
# MUST be set – there is no default; the application refuses to start without it.
# ──────────────────────────────────────────────────────────────────────────────
APP_ENCRYPTION_KEY=REPLACE_WITH_BASE64_32BYTE_KEY

# ──────────────────────────────────────────────────────────────────────────────
# PostgreSQL – local development & Docker Compose
# ──────────────────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=aurasentry
POSTGRES_USER=aurasentry
POSTGRES_PASSWORD=CHANGE_ME

# ──────────────────────────────────────────────────────────────────────────────
# Azure Service Principal (used for scanning & cost management)
# ──────────────────────────────────────────────────────────────────────────────
# Create an App Registration in Azure Entra ID with Reader + Cost Reader roles.
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=REPLACE_WITH_YOUR_CLIENT_SECRET
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# ──────────────────────────────────────────────────────────────────────────────
# Gemini API – Google AI remediation engine
# ──────────────────────────────────────────────────────────────────────────────
# https://aistudio.google.com/apikey
GEMINI_API_KEY=REPLACE_WITH_YOUR_API_KEY
GEMINI_MODEL_ID=gemini-2.5-flash

# ──────────────────────────────────────────────────────────────────────────────
# GitHub Container Registry (only needed for docker-compose.prod.yml)
# ──────────────────────────────────────────────────────────────────────────────
GITHUB_REPOSITORY=your-github-org/aura-sentry-core
